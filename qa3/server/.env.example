# ─── QuickApply Server Environment ─────────────────────────────────────
# Copy this file to .env and fill in your real keys

# Stripe Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Create 3 products: Starter, Pro, Ultra — each with monthly + annual price
STRIPE_PRICE_STARTER_MONTHLY=price_1T7B5BICZKAj7VsMHxohBWYL
STRIPE_PRICE_STARTER_ANNUAL=price_1T7BS8ICZKAj7VsMC8aREcOR
STRIPE_PRICE_PRO_MONTHLY=price_1T7B7zICZKAj7VsMIIZSQe9I
STRIPE_PRICE_PRO_ANNUAL=price_1T7BSlICZKAj7VsMbz97aVDI
STRIPE_PRICE_ULTRA_MONTHLY=price_1T7B9IICZKAj7VsMHPLC8pxj
STRIPE_PRICE_ULTRA_ANNUAL=price_1T7BT8ICZKAj7VsMkRy7zbGl

# Server
PORT=3000
FRONTEND_URL=chrome-extension://YOUR_EXTENSION_ID_HERE

# Security
API_SECRET=your_random_secret_string_min_32_chars_here
