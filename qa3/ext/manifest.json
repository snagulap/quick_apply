{
  "manifest_version": 3,
  "name": "QuickApply - AI Job Assistant",
  "version": "3.0.0",
  "description": "Auto-fill job applications, AI cover letters, CV-to-job ATS alignment & real payment subscriptions.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://indeed.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://glassdoor.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.workday.com/*",
    "https://js.stripe.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background/background.js" },
  "content_scripts": [{
    "matches": [
      "https://www.linkedin.com/*",
      "https://indeed.com/*",
      "https://www.indeed.com/*",
      "https://www.glassdoor.com/*",
      "https://glassdoor.com/*",
      "https://*.greenhouse.io/*",
      "https://*.lever.co/*",
      "https://*.workday.com/*"
    ],
    "js": ["content/content.js"],
    "css": ["content/content.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
