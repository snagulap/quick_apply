{
  "manifest_version": 3,
  "name": "QuickApply - AI Job Assistant",
  "version": "4.0.0",
  "description": "AI-powered job application assistant. Click the icon on any job page to open the sidebar.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open QuickApply"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [{
    "matches": [
      "https://www.linkedin.com/*",
      "https://indeed.com/*",
      "https://www.indeed.com/*",
      "https://www.glassdoor.com/*",
      "https://glassdoor.com/*",
      "https://*.greenhouse.io/*",
      "https://*.lever.co/*",
      "https://*.workday.com/*",
      "https://*.myworkdayjobs.com/*"
    ],
    "js": ["content/content.js"],
    "css": ["content/content.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
